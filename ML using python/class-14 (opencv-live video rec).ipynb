    "import cv2"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "e26b62ac",
   "metadata": {},
   "outputs": [],
   "source": [
    "v=cv2.VideoCapture(0)                 #here 0=webcam"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "962aae45",
   "metadata": {},
   "outputs": [],
   "source": [
    "while True:\n",
    "    ret,video=v.read()\n",
    "    cv2.imshow(\"liveclass\",video)\n",
    "    if cv2.waitKey(10)==ord(\"q\"):                     #ord id used to convert in ascii value\n",
    "        break\n",
    "v.release"
   ]
